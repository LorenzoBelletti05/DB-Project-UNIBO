# *.db
# *.sqlite
# *.sqlite3

# File temporanei di SQLite
*.db-journal
*.db-wal
*.db-shm
*.tmp
*~

# File temporanei della cartella Schema_ER
Schema_ER/*.db-journal
Schema_ER/*.db-wal
Schema_ER/*.db-shm

